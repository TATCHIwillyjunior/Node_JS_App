{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "timezone": "Europe/Paris",
  "schedule": [" 0 3 * * 0", " 0 18 * * 0"], //Now renovate will run on Sunday at 03:00 am and 18:00pm
  "packageRules": [
    {
      "matchPackagePatterns": ["*"],
      "automerge": false
    }
  ]
}
